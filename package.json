    "@tanstack/react-query": "^5.90.21",
    "better-auth": "^1.5.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react-native": "^0.575.0",
    "nativewind": "^4.2.2",
    "react": "19.2.3",
    "react-hook-form": "^7.71.2",
    "react-native": "0.84.0",
    "react-native-bootsplash": "^7.1.0",
    "react-native-gesture-handler": "^2.29.1",
