{
  "name": "YumQuick",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start",
    "start:fresh": "react-native start --reset-cache",
    "clean": "react-native clean",
    "clean:android": "cd android && cross-env GRADLE_USER_HOME=D:\\G gradlew clean",
    "clean:all": "react-native clean && pnpm install && cd android && cross-env GRADLE_USER_HOME=D:\\G gradlew clean",
    "apk:debug": "cd android && cross-env GRADLE_USER_HOME=D:\\G gradlew assembleDebug",
    "apk:release": "cd android && cross-env GRADLE_USER_HOME=D:\\G gradlew assembleRelease",
    "test": "jest",
    "test:ci": "jest --runInBand --coverage --coverageProvider=v8",
    "test:coverage": "jest --coverage --coverageProvider=v8",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "api": "node node_modules/tsx/dist/cli.mjs server/index.ts",
    "api:dev": "node node_modules/tsx/dist/cli.mjs watch server/index.ts",
    "prepare": "husky",
    "storybook": "cross-env STORYBOOK_ENABLED=true react-native start",
    "storybook:android": "cross-env STORYBOOK_ENABLED=true react-native run-android",
    "storybook:ios": "cross-env STORYBOOK_ENABLED=true react-native run-ios",
    "storybook:web": "storybook dev --config-dir .storybook-web --port 6006",
    "storybook:web:build": "storybook build --config-dir .storybook-web --output-dir storybook-static-web"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.5.3",
